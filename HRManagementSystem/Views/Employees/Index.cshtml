@model IEnumerable<HRManagementSystem.Models.Employee>

@{
    ViewData["Title"] = "Nhân sự";
}

<!-- PAGE HEADER -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
        <p class="mb-0" style="font-size:0.85rem;color:#64748b;">
            Quản lý toàn bộ nhân viên trong hệ thống
        </p>
    </div>
    <div class="d-flex gap-2">
        <div class="input-group" style="width:220px;">
            <span class="input-group-text bg-white border-end-0" style="border:1.5px solid #e2e8f0;border-radius:8px 0 0 8px;">
                <i class="bi bi-search text-muted" style="font-size:0.8rem;"></i>
            </span>
            <input type="text" class="form-control border-start-0 ps-0" placeholder="Tìm kiếm..."
                   style="border:1.5px solid #e2e8f0;border-left:none;border-radius:0 8px 8px 0;">
        </div>
        <a asp-action="Create" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="bi bi-plus-lg"></i> Thêm nhân viên
        </a>
    </div>
</div>

<!-- TABLE CARD -->
<div class="card">
    <div class="card-header">
        <span style="font-size:0.9rem;">
            <i class="bi bi-people-fill me-2 text-primary"></i>Danh sách nhân viên
        </span>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-secondary py-1 px-2" title="Lọc">
                <i class="bi bi-funnel" style="font-size:0.75rem;"></i>
            </button>
            <button class="btn btn-sm btn-outline-secondary py-1 px-2" title="Xuất Excel">
                <i class="bi bi-download" style="font-size:0.75rem;"></i>
            </button>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th style="padding-left:1.4rem;">Nhân viên</th>
                        <th>Phòng ban</th>
                        <th>Chức vụ</th>
                        <th>Email</th>
                        <th>Điện thoại</th>
                        <th>Trạng thái</th>
                        <th style="text-align:right;padding-right:1.4rem;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td style="padding-left:1.4rem;">
                                    <div class="d-flex align-items-center gap-3">
                                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(item.FullName ?? "NV")&background=5b6af0&color=fff&size=36&bold=true"
                                             style="width:36px;height:36px;border-radius:10px;flex-shrink:0;" alt="@item.FullName">
                                        <div>
                                            <div style="font-weight:600;font-size:0.875rem;">@item.FullName</div>
                                            <div style="font-size:0.72rem;color:#94a3b8;">#EMP-@item.Id.ToString("D4")</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge" style="background:#eef0fd;color:#5b6af0;font-weight:600;">
                                        @(item.Department?.Name ?? "—")
                                    </span>
                                </td>
                                <td style="color:#64748b;font-size:0.875rem;">@(item.Position?.Title ?? "—")</td>
                                <td style="color:#64748b;font-size:0.875rem;">@item.Email</td>
                                <td style="color:#64748b;font-size:0.875rem;">@item.PhoneNumber</td>
                                <td>
                                    <span class="badge" style="background:#f0fdf4;color:#22c55e;">
                                        <i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle;"></i>Đang làm
                                    </span>
                                </td>
                                <td style="text-align:right;padding-right:1.4rem;">
                                    <div class="d-flex gap-1 justify-content-end">
                                        <a href="#" class="btn btn-sm btn-outline-secondary py-1 px-2" title="Xem chi tiết">
                                            <i class="bi bi-eye" style="font-size:0.8rem;"></i>
                                        </a>
                                        <a href="#" class="btn btn-sm btn-outline-primary py-1 px-2" title="Chỉnh sửa">
                                            <i class="bi bi-pencil" style="font-size:0.8rem;"></i>
                                        </a>
                                        <a href="#" class="btn btn-sm py-1 px-2" title="Xoá"
                                           style="border:1.5px solid #fecaca;color:#ef4444;border-radius:8px;">
                                            <i class="bi bi-trash" style="font-size:0.8rem;"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <div style="color:#94a3b8;">
                                    <i class="bi bi-people" style="font-size:2.5rem;display:block;margin-bottom:0.75rem;"></i>
                                    <div style="font-size:0.9rem;font-weight:500;">Chưa có nhân viên nào</div>
                                    <div style="font-size:0.8rem;margin-top:0.25rem;">Thêm nhân viên đầu tiên để bắt đầu</div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model != null && Model.Any())
    {
        <div class="card-footer bg-transparent border-top d-flex align-items-center justify-content-between px-4 py-3"
             style="font-size:0.8rem;color:#64748b;">
            <span>Hiển thị @Model.Count() nhân viên</span>
            <nav>
                <ul class="pagination pagination-sm mb-0 gap-1">
                    <li class="page-item disabled">
                        <a class="page-link" style="border-radius:6px;border:1.5px solid #e2e8f0;">
                            <i class="bi bi-chevron-left" style="font-size:0.7rem;"></i>
                        </a>
                    </li>
                    <li class="page-item active">
                        <a class="page-link" style="border-radius:6px;background:#5b6af0;border-color:#5b6af0;">1</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" style="border-radius:6px;border:1.5px solid #e2e8f0;">
                            <i class="bi bi-chevron-right" style="font-size:0.7rem;"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>
